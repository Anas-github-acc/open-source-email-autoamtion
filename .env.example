# Supabase configuration for the database and authentication backend
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_PROJECT_ID=your-supabase-project-id
SUPABASE_SECRET_KEY=your-supabase-secret-key

# API configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# GitHub settings for the fork-and-run workflow engine integration
GITHUB_REPO_OWNER=your-github-username-or-org
GITHUB_REPO_NAME=Dumpmail-Fork

# GitHub App Configuration (Hybrid OAuth + GitHub App flow)
# 1. Create a GitHub App with permissions: Actions (read/write), Metadata (read)
# 2. Store App ID, Client ID, and PEM Private Key (can be Base64-encoded or raw string with \n)
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=your-github-app-private-key-pem-or-base64
NEXT_PUBLIC_GITHUB_APP_NAME=your-github-app-slug-name
